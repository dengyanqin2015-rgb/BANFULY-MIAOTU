# Gemini API Keys
# 默认免费 Key (用于对话、识图、文案)
GEMINI_API_KEY=

# 专门用于生图的付费 Key (用于 ImageNode 生成)
# 如果不填写，生图将回退使用上面的默认 Key 或用户手动输入的 Key
VITE_PAID_IMAGE_API_KEY=

# 豆包 (Doubao/火山引擎) 生图配置
VITE_DOUBAO_API_KEY=
VITE_DOUBAO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/images/generations
VITE_DOUBAO_MODEL_ID=
